# ========== 環境設定 ==========
ENVIRONMENT=development

# ========== GCP 設定 ==========
GCP_PROJECT_ID=sandbox-nagauchi
PORT=8080

# ========== Slack 設定 ==========
# Slack Bot Token (xoxb-... で始まる)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# ========== Google Cloud 設定 ==========
# サービスアカウント JSON ファイルのパス（ローカル開発環境用）
# Cloud Run 環境では Secret Manager から取得される
GOOGLE_SERVICE_ACCOUNT_JSON="client_secret_626945538637-sdoiptibp2i2ogrlct1r3psm8auepahh.apps.googleusercontent.com.json"

# 管理用スプレッドシートの ID
MANAGEMENT_SPREADSHEET_ID=your-spreadsheet-id-here

# Google Drive のルートフォルダ ID（請求書保存先の親フォルダ）
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# ========== 管理者設定 ==========
# グループ DM に追加する管理者のユーザーID（カンマ区切り）
ADMIN_GROUP_MEMBERS=U12345678901,U98765432109
