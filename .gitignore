# --- Python Standard ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Environment Variables & Secrets (Security Critical!) ---
# ローカルの秘密設定ファイル
.env
env_vars.yaml

# Google Cloud Platform 認証情報
# クライアントシークレットとサービスアカウントキーをまとめて除外
client_secret_*.json
sandbox-*.json

# ユーザーごとの認証トークン (個人データであり機密情報)
user_tokens/*.pickle

# --- Logs & Debug ---
*.log
modal_debug.log

# --- Temporary Files & Tool Outputs ---
list.txt
.DS_Store
Thumbs.db

# --- IDE Specific ---
.vscode/
.idea/